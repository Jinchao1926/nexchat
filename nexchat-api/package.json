{
  "name": "nexchat-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "test": "node --import tsconfig-paths/register.js --import tsx --test \"src/**/*.test.ts\"",
    "build": "tsc && tsc-alias",
    "format": "prettier --write .",
    "dev": "tsx watch --import tsconfig-paths/register.js src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate && pnpm dlx auth@latest generate --output src/db/schema/auth.ts",
    "db:migrate": "node --import tsx src/db/migrate.ts && pnpm dlx auth@latest migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  }
}
